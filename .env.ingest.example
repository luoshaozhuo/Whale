# Select the three ingest backends independently.
# Supported values:
#   WHALE_INGEST_DATABASE_BACKEND    : sqlite | postgresql (default)
#   WHALE_INGEST_STATE_CACHE_BACKEND : relational | redis (default)
#   WHALE_INGEST_MESSAGE_BACKEND     : relational_outbox | redis_streams | kafka (default)
#
# The defaults (postgresql + redis + kafka) require docker compose services.
# Use sqlite + relational + relational_outbox for a zero-dependency local setup.
WHALE_INGEST_DATABASE_BACKEND=postgresql
WHALE_INGEST_STATE_CACHE_BACKEND=redis
WHALE_INGEST_MESSAGE_BACKEND=kafka

# SQLite file path (used only when WHALE_INGEST_DATABASE_BACKEND=sqlite).
#WHALE_INGEST_DB_PATH=.data/ingest/whale.ingest.db

# PostgreSQL backend — required when WHALE_INGEST_DATABASE_BACKEND=postgresql.
WHALE_INGEST_DB_HOST=127.0.0.1
WHALE_INGEST_DB_PORT=5432
WHALE_INGEST_DB_NAME=whale_ingest
WHALE_INGEST_DB_USERNAME=whale
WHALE_INGEST_DB_PASSWORD=whale

# Redis state-cache backend — required when WHALE_INGEST_STATE_CACHE_BACKEND=redis.
WHALE_INGEST_REDIS_HOST=127.0.0.1
WHALE_INGEST_REDIS_PORT=16379
WHALE_INGEST_REDIS_DB=0
WHALE_INGEST_REDIS_STATE_HASH_KEY=whale:ingest:state
WHALE_INGEST_STATION_ID=station-dev-001

# Kafka backend — required when WHALE_INGEST_MESSAGE_BACKEND=kafka.
WHALE_INGEST_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
WHALE_INGEST_KAFKA_TOPIC=whale.ingest.state_snapshot.v1
WHALE_INGEST_KAFKA_ACK_TIMEOUT_SECONDS=5.0

# Optional Redis Streams backend — required when WHALE_INGEST_MESSAGE_BACKEND=redis_streams.
#WHALE_INGEST_MESSAGE_REDIS_URL=redis://127.0.0.1:16379/0
#WHALE_INGEST_MESSAGE_REDIS_STREAM_KEY=whale:ingest:state_snapshot:v1
